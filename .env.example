# ============================================
# LinkedInWrites — Environment Variables
# ============================================
# HOW TO USE:
# 1. Copy this file and rename it to .env.local
# 2. Fill in your real values in .env.local
# 3. Never commit .env.local to GitHub
# ============================================

# OpenAI — used to generate 3 LinkedIn post variations
# Get your key at: platform.openai.com/api-keys
# ⚠️  Server-side only — never expose to browser
OPENAI_API_KEY=

# Supabase — used for user auth (login/signup) and database (personas + saved posts)
# Get these from: supabase.com → your project → Settings → API
# ✅  Safe to expose to browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
